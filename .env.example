# Copy to .env.local for local development. Never commit real values.
# Production and preview secrets belong in Vercel project settings (see docs/DEPLOYMENT.md).

# App identity (optional — defaults are safe for M0/M1)
# NEXT_PUBLIC_APP_NAME=lyt-onboarding

# Node environment is set automatically by Vercel and `next dev` / `next start`.
# NODE_ENV=development
